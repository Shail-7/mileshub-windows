# Contact-form email delivery (SMTP via Nodemailer).
# Copy this file to `.env.local` and fill in real values, then `npm run dev`.
# `.env.local` is gitignored — never commit real credentials.

# --- SMTP server (required) ---
# Use the outgoing mail server for your Mhwindows.co.uk mailbox / provider.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
# "true" for implicit TLS (port 465), otherwise leave blank/false (STARTTLS on 587).
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password

# --- Addresses (optional) ---
# Where leads are delivered. Defaults to Sales@Mhwindows.co.uk if unset.
CONTACT_TO=Sales@Mhwindows.co.uk
# The "From" address. Defaults to SMTP_USER. Should be on a domain you're
# allowed to send as (often must match SMTP_USER to pass SPF/DKIM).
CONTACT_FROM=Sales@Mhwindows.co.uk
